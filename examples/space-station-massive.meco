@meco 1
@start npc-line

// A deliberately large, deeply compositional grammar for mundane NPC speech
// on procedurally generated space stations. Each domain branches through
// concepts, perspectives, sentence structures, phrases, and vocabulary.

# npc-line
- [8] @food-line
- [7] @maintenance-line
- [7] @transit-line
- [7] @work-line
- [6] @housing-line
- [6] @commerce-line
- [5] @health-line
- [5] @security-line
- [5] @bureaucracy-line
- [5] @entertainment-line
- [4] @communication-line
- [4] @power-line
- [4] @gravity-line
- [4] @life-support-line
- [5] @cargo-line
- [4] @science-line
- [3] @superstition-line
- [4] @drone-line
- [5] @navigation-line
- [4] @sanitation-line
- [4] @family-line
