[project]
title = Mecojoni Demo
version = 1.0
custom_resources = main/data

[bootstrap]
main_collection = /main/main.collectionc

[input]
game_binding = /input/game.input_bindingc

[script]
shared_state = 1

[display]
width = 640
height = 360
high_dpi = 0

[graphics]
default_texture_min_filter = nearest
default_texture_mag_filter = nearest
